apiVersion: fournos.dev/v1
kind: FournosJob
metadata:
  name: {{ ctx.final_job_name }}
  namespace: {{ args.namespace }}
  {% if args.ci_label -%}
  labels:
    ci-run: {{ args.ci_label }}
  {%- endif %}
spec:
  owner: {{ args.owner }}
  displayName: {{ args.display_name }}
  cluster: {{ args.cluster_name }}
  exclusive: {{ args.exclusive }}
  pipeline: {{ args.pipeline_name }}
  forge:
    project: {{ args.project }}
    args:
{{ args.args | toyaml | indent(6, true)}}
    configOverrides:
{{ args.variables_overrides | toyaml | indent(6, true)}}
  env:
{{ args.env | toyaml | indent(4, true) }}
